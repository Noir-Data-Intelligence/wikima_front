# Copy to .env and adjust. See ../back for the backend (docker compose up).

# false = talk to the real WiKima backend; true/absent = in-memory mock (no backend needed).
VITE_MOCK_AUTH=false

# Base path the app calls; in dev Vite proxies it to VITE_API_PROXY_TARGET
# (stripping the /api prefix — the backend serves routes at the root).
# In production point VITE_API_URL at the deployed API instead.
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8080
